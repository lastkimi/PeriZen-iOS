default_platform(:ios)

platform :ios do
  before_all do
    # Load App Store Connect API Key
    app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_filepath: ENV["ASC_KEY_FILEPATH"],
      in_house: false
    )
  end

  desc "Fetch or create certificates and profiles"
  lane :sync_certificates do
    match(
      type: "appstore",
      readonly: false, # Or true if certificates already exist
      git_url: ENV["MATCH_GIT_URL"],
      app_identifier: ["com.slmcamp.PeriZen"]
    )
  end

  desc "Push a new release build to the App Store"
  lane :release do
    echo(message: "🚀 Fetching certificates...")
    sync_certificates
    
    echo(message: "🚀 Starting build process for PeriZen...")
    
    # Generate the project first if it doesn't exist
    sh("cd .. && xcodegen generate")

    # Build the app using gym
    build_app(
      project: "PostureGuardiOS.xcodeproj",
      scheme: "PostureGuardiOS",
      export_method: "app-store",
      export_options: {
        provisioningProfiles: {
          "com.slmcamp.PeriZen" => "match AppStore com.slmcamp.PeriZen"
        }
      }
    )
    
    echo(message: "🚀 Uploading binary and metadata...")
    
    deliver(
      submit_for_review: false,
      automatic_release: true,
      force: true, # Skip HTML report validation
      skip_binary_upload: false, # Upload the binary we just built
      skip_screenshots: true
    )
    
    echo(message: "✅ App and Metadata successfully delivered to App Store Connect.")
  end

  desc "Upload only the IPA to bypass metadata crashes"
  lane :upload_ipa do
    deliver(
      ipa: "PostureGuardiOS.ipa",
      skip_metadata: true,
      skip_screenshots: true,
      submit_for_review: false,
      force: true
    )
  end

  desc "Upload only the screenshots"
  lane :upload_screenshots do
    deliver(
      skip_metadata: true,
      skip_binary_upload: true,
      submit_for_review: false,
      overwrite_screenshots: true,
      force: true
    )
  end
end
